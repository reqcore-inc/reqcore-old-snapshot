    "serialize-javascript": "7.0.5",
    "underscore": "1.13.8",
    "h3": "1.15.11",
    "devalue": "5.8.1",
    "unhead": "2.1.13",
    "uuid": "14.0.0",
    "fast-xml-builder": "1.2.0",
    "kysely": "0.28.17",
    "simple-git": "3.36.0",
    "protobufjs": "8.6.4",
    "form-data": "4.0.6"
  }
